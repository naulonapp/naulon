# naulon — copy to .env and fill. .env is gitignored. NEVER commit secrets.
# Custody-free: we never pool USDC. Wallets sign; settlement is wallet-to-wallet.
#
# Works for ANY publisher. The values below are generic; for a ready-made setup
# see examples/meridian/.env.example.

# ── Payment rail ────────────────────────────────────────────────────────────
# mock  = settle offline, no creds (default; great for local dev + demos)
# gateway = real Circle Gateway batching (needs a funded BUYER_PRIVATE_KEY)
PAYMENT_MODE=mock

# ── Settlement network ──────────────────────────────────────────────────────
# Which Circle Gateway chain the gate tolls on. One switch drives the whole rail
# (x402 quote, settlement body, discovery manifest, buyer client, AND the
# testnet-vs-mainnet facilitator). All constants are baked in per network
# (see packages/shared/src/networks.ts), so going live is just changing this value.
#   arcTestnet  = Circle's stablecoin-native L1 testnet (default; keyless, free)
#   baseSepolia = Base testnet (keyless, free)
#   base        = Base MAINNET — real USDC; needs a funded BUYER_PRIVATE_KEY
SETTLEMENT_NETWORK=arcTestnet

# ── Circle Gateway / Nanopayments ───────────────────────────────────────────
# The testnet facilitator is keyless; CIRCLE_API_KEY is optional (rate limits).
CIRCLE_API_KEY=
# Facilitator endpoint is auto-selected from SETTLEMENT_NETWORK (testnet networks →
# gateway-api-testnet.circle.com, base → gateway-api.circle.com). Leave blank unless
# you must pin a custom endpoint; a value here overrides the per-network default.
GATEWAY_API_URL=

# ── Arc self-relay (on-chain memo) settlement ───────────────────────────────
# ONLY used when SETTLEMENT_NETWORK is a memo-capable chain (Arc — it ships the Memo
# predeploy; Base does not). On such a network the gate self-relays the buyer's signed
# USDC EIP-3009 transfer through the Memo contract (emitting an indexed Memo event for
# offchain reconciliation) instead of handing it to Circle's facilitator. The relayer
# is an EOA (the Memo precompile is EOA-only) that pays gas (native USDC on Arc) but
# NEVER touches the transferred funds (buyer→author by the buyer's authorization) —
# custody-free holds. Leave blank on Base / Base Sepolia.
RELAYER_PRIVATE_KEY=
# Override the Arc USDC EIP-712 domain `name` ONLY if it is not the standard "USD Coin"
# (PREFLIGHT: confirm against the on-chain USDC name() before the first real settle —
# a mismatch makes both the off-chain pre-verify and the on-chain transfer reject a
# valid signature). Leave blank to use the default.
USDC_EIP712_NAME=
# Validity window (seconds) advertised in the x402 quote. Circle's Gateway facilitator
# requires >= 7 days (604800s) remaining at verify time; default 8d gives ~1 day of
# margin. Keep >= 604900 (floor + the SDK's 100s buffer). Below it, non-SDK buyers
# fail authorization_validity_too_short.
X402_MAX_TIMEOUT_SECONDS=691200

# ── Tollgate (seller side) ──────────────────────────────────────────────────
TOLLGATE_PORT=8402
ORIGIN_URL=http://localhost:3000     # the site the gate sits in front of
DEFAULT_PRICE_USDC=0.001             # per machine read (floor $0.000001)
CITATION_MULTIPLIER=5                # a citation costs this x a read; 1 = same price
ARTICLE_PATH_PREFIXES=essays,articles,posts   # which URL prefixes are gateable

# How the gate maps an article slug -> its author(s):
#   set CREDITS_API_URL  -> the gate fetches `${url}/credits/:slug` from your CMS
#   leave it blank       -> the gate reads the local JSON fixture below
CREDITS_API_URL=
CREDITS_API_TOKEN=
CREDITS_FIXTURES=./examples/meridian/credits.json

# Settlement emit (naulon -> publisher earnings ledger). After a paid read the
# gate POSTs a signed event to ${ORIGIN_URL}/api/credits/settlement. Shared HMAC
# secret; must match the publisher's value.
# Leave blank -> emit is dark (the gate still tolls + serves; it just doesn't
# report earnings), so the no-creds demo loop keeps working.
CREDITS_SETTLEMENT_SECRET=
# Crash-safe at-least-once delivery. The gate tries once on the hot path; a
# background drain re-sends anything unacked (boot sweep + every interval).
# Defaults are sane; override only to tune. Set the interval to 0 on serverless
# and drive the drain with a cron instead of a live loop.
SETTLEMENT_OUTBOX_PATH=./data/settlement-outbox.jsonl
SETTLEMENT_MAX_ATTEMPTS=5
SETTLEMENT_TIMEOUT_MS=4000
SETTLEMENT_DRAIN_INTERVAL_MS=60000

# ── Tollgate hardening ──────────────────────────────────────────────────────
# All optional; safe defaults shown. See README "Hardening".
TOLLGATE_SECRET=             # HMAC secret signing 402 nonces; ephemeral if unset (set for multi-instance)
NONCE_TTL_SECONDS=300        # how long an issued 402 nonce stays valid (also the replay window)
RATE_LIMIT_RPM=120           # sustained per-client requests/min; 0 disables rate limiting
RATE_LIMIT_BURST=40          # short-burst allowance before a 429
TRUST_PROXY=false            # trust X-Forwarded-For for client IP (only behind a proxy YOU control)
BOT_AUTH_ALLOW_HTTP=false     # Web Bot Auth: allow http/loopback key directories — local signer fixtures ONLY
BOT_AUTH_SIGNING_KEY=         # our Web Bot Auth Ed25519 seed (SECRET; `node scripts/wba-keygen.mjs`) —
                              # gate serves+signs the key directory, wayfarer signs its requests
BOT_AUTH_SIGNATURE_AGENT=     # directory host the wayfarer advertises (must serve OUR directory), e.g. naulon.app

# ── Wayfarer (paying agent) ─────────────────────────────────────────────────
BUYER_ADDRESS=               # agent wallet address  (run `make generate-wallets`)
BUYER_PRIVATE_KEY=           # agent wallet signing key  (SECRET; required for gateway mode)
WAYFARER_BUDGET_USDC=0.10    # total the agent may spend per research run
# ── Decision policy (server-config, never model-controlled). Unset ⇒ defaults. ──
# WAYFARER_ALLOW_DOMAINS=    # allowlist of publisher hosts (comma-sep); anything else is skipped
# WAYFARER_DENY_DOMAINS=     # hosts never paid (comma-sep); wins over the allowlist
# WAYFARER_PER_DOMAIN_CAP=   # max essays paid per host per run
# WAYFARER_APPROVAL_USDC=    # a toll at/above this needs human approval (not auto-paid)
# WAYFARER_KILL_SWITCH=false # true halts all new spend (held-license re-reads still free)
DEPOSIT_AMOUNT_USDC=1        # USDC deposited into the Gateway Wallet at run start (gateway mode)
OPENAI_API_KEY=              # optional; enables real LLM decisions (mock if unset)
# TOLLGATE_URL=              # tollgate the agent pays; defaults to the local tollgate
# Discovery source (precedence: RSS_URL > PUBLISHER_URL > CATALOG_URL > bundled demo)
# PUBLISHER_URL=            # publisher base; the agent reads ${PUBLISHER_URL}/rss.xml
# RSS_URL=                  # explicit feed URL (overrides PUBLISHER_URL/rss.xml)
# SITEMAP_URL=              # reserved; not parsed yet (RSS gives latest-N only)
# CATALOG_URL=              # bespoke catalog of {slug,title,summary} the agent discovers from
# WAYFARER_LICENSE_PATH=./data/wayfarer-licenses.json  # where the agent caches its
                             # Citation Licenses so a live one re-reads an essay free

# ── Dashboard (operator console) ────────────────────────────────────────────
# The self-host window onto your gate: health, live toll traffic, earnings, and
# config sanity. Read-only — articles/wallets/prices live in your credits source
# + env, not here. Full guide: docs/operating.md.
DASHBOARD_PORT=8403
DASHBOARD_BIND=127.0.0.1      # localhost-only by default (private ops console).
DASHBOARD_AUTH=              # "user:pass" — HTTP Basic, REQUIRED to bind wider than
                             # loopback. Wide bind with no auth (and not public) =
                             # the dashboard refuses to serve, so wallets can't leak.
DASHBOARD_PUBLIC=false       # true = serve ONLY the public earnings page (wallets
                             # masked, ops hidden). The shareable "authors earn" proof.
GATE_URL=http://127.0.0.1:8402  # your gate, for the health panel (its /healthz).
# Ops traffic needs the observation log ON — set OBSERVATIONS_BACKEND=jsonl below,
# else the traffic panel stays empty (the gate records nothing by default).

# ── Attribution & settlement ────────────────────────────────────────────────
# Accrue each author's tolls until they clear this, then settle in one payout.
MIN_PAYOUT_USDC=0.005
# Which co-author gets the single on-chain leg when two tie for the top share.
# "wallet" (default) = by address, so it's independent of credits-graph order;
# "input" = keep the graph order. The full split is always recorded regardless.
PRIMARY_PAYEE_TIEBREAK=wallet
# Pay co-authors directly on-chain (split-at-source) on multi-author articles instead
# of routing the whole toll to the primary author. Off (default) = the stock single
# recipient leg; the rest of the split is recorded for off-protocol payout. On = the
# primary's content-gating leg drops to its own share and each other co-author gets a
# direct, deferred buyer→author leg. The buyer's total is unchanged. Custody-free either
# way. (A multi-tenant resolver sets this per publisher instead of using this env.)
COAUTHOR_ONCHAIN_SPLIT=false
# Ledger files default to ./data/ at the repo root; override if you must.
# EVENTS_PATH=./data/events.jsonl
# PAYOUTS_PATH=./data/payouts.jsonl

# ── Storage backend ─────────────────────────────────────────────────────────
# Local dev + a single box: leave both on the defaults (a JSONL file + in-process
# nonces, no creds). Serverless / multi-instance (e.g. Vercel): set both to
# "supabase" so the ledger and the spent-nonce set live in a shared Postgres and
# every instance agrees. Apply supabase/migrations/0001_naulon.sql to the project.
EVENTS_BACKEND=jsonl          # jsonl (default) | supabase
NONCE_BACKEND=memory          # memory (default) | supabase
# Where buyer-authorized EXTRA settlement legs wait for their deferred on-chain settle
# (operator/co-author legs beyond the synchronous author leg). "supabase" survives a
# restart and settles exactly-once across instances; drained by drainPendingLegs.
# For "supabase", apply supabase/migrations/0002_pending_legs_observations.sql.
PENDING_LEGS_BACKEND=memory   # memory (default) | supabase
# Required only when a *_BACKEND above is "supabase". SERVICE_KEY is a SECRET —
# the service-role key from Supabase → Project Settings → API. Never commit it.
SUPABASE_URL=                 # https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_EVENTS_TABLE=naulon_events   # override only if you renamed the table
SUPABASE_NONCES_TABLE=naulon_nonces
SUPABASE_PENDING_LEGS_TABLE=naulon_pending_legs  # deferred extra-leg authorizations
SUPABASE_REVOCATIONS_TABLE=naulon_revocations  # CLT revocation denylist

# ── Observations (the audit/observability plane) ────────────────────────────
# The negative space the settlement ledger never sees: crawlers served free,
# agents denied at the 402, agents that paid. "off" (default) emits nothing — the
# open core stays quiet unless a deploy opts in. "jsonl" appends to a local file
# (single box); "supabase" streams into a shared table (multi-instance / a
# downstream embedder's audit plane). For supabase, apply
# supabase/migrations/0002_pending_legs_observations.sql and set SUPABASE_URL /
# SUPABASE_SERVICE_KEY above.
OBSERVATIONS_BACKEND=off              # off (default) | jsonl | supabase
OBSERVATIONS_PATH=./data/observations.jsonl   # jsonl backend only
SUPABASE_OBSERVATIONS_TABLE=naulon_observations  # override only if you renamed it

# ── Citation License Tokens (CLT) ───────────────────────────────────────────
# Signed, verifiable receipts handed to a paying agent (see docs/citation-license.md).
# On by default; additive and harmless. Offline/mock mints with an ephemeral key.
LICENSES_ENABLED=true                 # true (default) | false
# Ed25519 private key (PKCS8 PEM or base64 DER) that SIGNS licenses. SECRET.
# REQUIRED once PAYMENT_MODE=gateway OR a *_BACKEND is supabase — an ephemeral key
# breaks verification across serverless instances. Generate one with:
#   node -e "const{generateKeyPairSync}=require('crypto');console.log(generateKeyPairSync('ed25519',{privateKeyEncoding:{type:'pkcs8',format:'pem'}}).privateKey)"
LICENSE_SIGNING_KEY=
LICENSE_TTL_SECONDS=600               # re-read window; <=3600 (TTL is the kill switch)
LICENSE_ISSUER=                       # defaults to naulon:<gate host>
LICENSE_PAYEES_MODE=full              # full (embed the split, default) | hashed
LICENSE_ONLINE_CHECK=false            # consult the jti revocation seam on the online tier (P2)
# Holder-of-key (P5): bind licenses to the payer wallet (RFC 7800 cnf) and require an
# EIP-191 proof-of-possession on re-read — a captured token is then useless without the
# wallet key. Off = short-TTL bearer licenses (the demo loop is unaffected). Needs a
# signing-capable buyer wallet (BUYER_PRIVATE_KEY; the mock path uses a dev key).
LICENSE_POP=false
LICENSE_POP_WINDOW_SECONDS=120        # proof freshness + replay window (seconds); <=600

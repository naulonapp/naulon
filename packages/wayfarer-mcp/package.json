{
  "name": "@naulon/wayfarer-mcp",
  "version": "0.2.1",
  "description": "Model Context Protocol server that lets any LLM discover, quote, pay, and cite naulon-tolled sources — BYO wallet, local stdio, the wayfarer brain in-process.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naulonapp/naulon.git",
    "directory": "packages/wayfarer-mcp"
  },
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "bin": {
    "wayfarer-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@naulon/shared": "^0.1.2",
    "@naulon/wayfarer": "^0.1.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  }
}

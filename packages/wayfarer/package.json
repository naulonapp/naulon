{
  "name": "@naulon/wayfarer",
  "version": "0.1.1",
  "description": "The naulon paying agent: discover → quote → appraise → decide → pay → ground. Budgeted x402 buying over Circle Gateway on Arc, with reusable Citation Licenses (pay once, re-read free).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naulonapp/naulon.git",
    "directory": "packages/wayfarer"
  },
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@naulon/shared": "^0.1.2",
    "@circle-fin/x402-batching": "^3.2.0",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "viem": "^2.52.2"
  },
  "engines": {
    "node": ">=22"
  }
}

{
  "name": "@naulon/shared",
  "version": "0.1.1",
  "description": "The naulon contract layer: env config, credits + license types, settlement and attribution wire types, event/observation sinks, and the money primitives (network constants, EIP-3009). Builds on @naulon/sdk and re-exports it, so downstream packages get one import.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naulonapp/naulon.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./attribution": {
      "types": "./dist/attribution.d.ts",
      "import": "./dist/attribution.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@naulon/sdk": "^0.1.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  }
}

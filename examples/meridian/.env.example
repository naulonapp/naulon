# First worked example: Meridian — a (fictional) essays publication.
# Copy these over your root .env to point the tollgate at Meridian.

ORIGIN_URL=https://meridian.example
ARTICLE_PATH_PREFIXES=essays

# Use the bundled fixture credits graph for a no-backend demo...
CREDITS_FIXTURES=./examples/meridian/credits.json
# ...or resolve live from the publisher's own credits API instead:
# CREDITS_API_URL=https://meridian.example/api
# CREDITS_API_TOKEN=
